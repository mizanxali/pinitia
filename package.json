{
  "name": "pinitia",
  "version": "1.0.0",
  "description": "Pinitia is a prediction market platform where users bet on Google Maps venue metrics — review velocity and rating movement. It is built as an Initia EVM appchain (Minitia) for the INITIATE Hackathon 2026.",
  "main": "index.js",
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "frontend:start": "npm run start --prefix frontend",
    "frontend:lint": "npm run lint --prefix frontend",
    "frontend:install": "npm install --prefix frontend",
    "oracle:dev": "npm run dev --prefix oracle",
    "oracle:start": "npm run start --prefix oracle",
    "oracle:seed": "npm run seed --prefix oracle",
    "oracle:install": "npm install --prefix oracle",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test",
    "contracts:deploy": "cd contracts && forge script script/Deploy.s.sol --broadcast",
    "install:all": "npm install && npm install --prefix frontend && npm install --prefix oracle"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizanxali/pinitia.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/mizanxali/pinitia/issues"
  },
  "homepage": "https://github.com/mizanxali/pinitia#readme",
  "devDependencies": {
    "@biomejs/biome": "2.4.8"
  }
}
